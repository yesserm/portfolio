---
import { getCollection } from "astro:content";
import BaseLayout from "@layout/BaseLayout.astro";
import Header from "@components/layout/Header.astro";
import SEO from "@components/SEO.astro";
import { site } from "@lib/site";
import { formatBlogDate, getBlogUrl, sortPosts } from "@lib/blog";

const posts = sortPosts(await getCollection("blog"));

const meta = {
  title: `Blog — ${site.siteName}`,
  description: "Entradas tecnicas en espanol e ingles sobre desarrollo web, mobile y arquitectura.",
  url: `${site.domain}/blog`,
  image: site.socialImage,
  keywords: "blog, articulos, Yesser Miranda, desarrollo web, mobile, software architecture",
};
---

<BaseLayout title={meta.title}>
  <Fragment slot="head">
    <SEO
      title={meta.title}
      description={meta.description}
      url={meta.url}
      image={meta.image}
      keywords={meta.keywords}
      breadcrumb={[
        { position: 1, name: "Home", item: site.domain },
        { position: 2, name: "Blog", item: `${site.domain}/blog` },
      ]}
    />
  </Fragment>

  <Fragment slot="header">
    <Header />
  </Fragment>

  <section class="px-6 py-20">
    <div class="mx-auto max-w-4xl">
      <h1 class="text-3xl font-bold text-white">Blog</h1>
      <p class="mt-2 text-slate-400">Entradas y notas en espanol e ingles.</p>

      <div class="mt-8 grid gap-6">
        {posts.map((post) => (
          <article class="rounded-lg border border-slate-800 bg-slate-900/60 p-6">
            <p class="text-xs font-semibold uppercase tracking-wide text-cyan-300">{post.data.lang}</p>
            <a href={getBlogUrl(post.data.lang, post.data.slug)} class="mt-2 block text-xl font-semibold text-white hover:text-cyan-300">
              {post.data.title}
            </a>
            <p class="mt-2 text-sm text-slate-400">{formatBlogDate(post.data.pubDate, post.data.lang)}</p>
            <p class="mt-3 text-slate-300">{post.data.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
