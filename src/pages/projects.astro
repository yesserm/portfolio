---
import BaseLayout from "@layout/BaseLayout.astro";
import Header from "@components/layout/Header.astro";
import SEO from "@components/SEO.astro";
import { site } from "@lib/site";

const meta = {
  title: `Proyectos — ${site.siteName}`,
  description: "Proyectos destacados y enlaces a repositorios. Página en construcción.",
  url: `${site.domain}/projects`,
  image: site.socialImage,
  keywords: "proyectos, portfolio, repositorios, Yesser Miranda"
};
---

<BaseLayout title={meta.title}>
  <Fragment slot="head">
    <SEO
      title={meta.title}
      description={meta.description}
      url={meta.url}
      image={meta.image}
      keywords={meta.keywords}
      breadcrumb={[{ position: 1, name: 'Home', item: site.domain }, { position: 2, name: 'Proyectos', item: `${site.domain}/projects` }]}
    />
  </Fragment>

  <Fragment slot="header">
    <Header />
  </Fragment>

  <section class="flex items-center justify-center min-h-[60vh] px-6 py-20">
    <div class="text-center">
      <h1 class="text-3xl font-bold text-white mb-4">Proyectos</h1>
      <p class="text-slate-300">En construcción</p>
      <p class="mt-4 text-sm text-slate-400">Aquí se mostrará un listado de repositorios y proyectos con enlaces a GitHub.</p>
    </div>
  </section>
</BaseLayout>
