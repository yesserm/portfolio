---
const contacts = [
  { label: "Email", value: "yessermiranda15@gmail.com", href: "mailto:yessermiranda15@gmail.com" },
  { label: "GitHub", value: "Ver perfil", href: "https://github.com/yessermiranda" },
  { label: "LinkedIn", value: "Conectemos", href: "https://www.linkedin.com/" },
];
---

<section id="contact" class="scroll-mt-24 px-6 py-20 sm:py-28" aria-labelledby="contact-title">
  <div class="mx-auto max-w-6xl rounded-2xl border border-slate-800 bg-slate-900/50 px-6 py-12 sm:px-12 sm:py-16">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-300">Contacto</p>
      <h2 id="contact-title" class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">¿Tienes una idea o un reto técnico?</h2>
      <p class="mt-4 leading-7 text-slate-400">Estoy disponible para colaboraciones, productos nuevos y conversaciones sobre desarrollo web o móvil.</p>
    </div>

    <div class="mt-10 grid gap-3 sm:grid-cols-3">
      {contacts.map((contact) => (
        <a href={contact.href} target={contact.href.startsWith("http") ? "_blank" : undefined} rel={contact.href.startsWith("http") ? "noreferrer" : undefined} class="rounded-xl border border-slate-800 bg-slate-950/40 p-5 transition hover:border-slate-600 hover:bg-slate-900 focus:outline-none focus:ring-2 focus:ring-cyan-300">
          <p class="text-sm font-medium text-slate-400">{contact.label}</p>
          <p class="mt-2 font-medium text-white">{contact.value}</p>
        </a>
      ))}
    </div>
  </div>
</section>
