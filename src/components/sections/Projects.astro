---
const projects = [
  {
    category: "Web platform",
    title: "Operaciones en un solo lugar",
    description: "Una interfaz enfocada en simplificar flujos internos, hacer visibles las prioridades y reducir trabajo manual.",
    stack: ["Astro", "TypeScript", "Tailwind CSS"],
  },
  {
    category: "Mobile product",
    title: "Experiencias móviles útiles",
    description: "Aplicaciones centradas en tareas reales, con recorridos claros y una base técnica mantenible para evolucionar.",
    stack: ["React Native", "Expo", "REST APIs"],
  },
  {
    category: "Backend & APIs",
    title: "Servicios preparados para crecer",
    description: "APIs con contratos claros, autenticación y estructuras que facilitan el mantenimiento de productos digitales.",
    stack: ["ASP.NET", "C#", "PostgreSQL"],
  },
];
---

<section id="projects" class="scroll-mt-24 px-6 py-20 sm:py-28" aria-labelledby="projects-title">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-300">Proyectos</p>
      <h2 id="projects-title" class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Productos digitales pensados para usarse.</h2>
      <p class="mt-4 leading-7 text-slate-400">Cada proyecto equilibra una experiencia simple para las personas con una implementación sólida para los equipos.</p>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {projects.map((project) => (
        <article class="group flex min-h-72 flex-col rounded-2xl border border-slate-800 bg-slate-900/50 p-7 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-slate-700 hover:bg-slate-900">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-300">{project.category}</p>
          <h3 class="mt-5 text-xl font-semibold text-white">{project.title}</h3>
          <p class="mt-4 leading-7 text-slate-400">{project.description}</p>
          <ul class="mt-auto flex flex-wrap gap-2 pt-7" aria-label={`Tecnologías: ${project.stack.join(", ")}`}>
            {project.stack.map((technology) => <li class="rounded-md bg-slate-800/80 px-2.5 py-1 text-xs text-slate-300">{technology}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
