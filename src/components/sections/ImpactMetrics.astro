---
const metrics = [
  {
    value: "5+",
    label: "Years building",
    detail: "Full-stack, mobile, and API delivery experience."
  },
  {
    value: "20+",
    label: "Projects delivered",
    detail: "From product websites to operational applications."
  },
  {
    value: "10+",
    label: "Mobile experiences",
    detail: "React Native and Expo apps designed for real users."
  },
  {
    value: "100k+",
    label: "Users impacted",
    detail: "Digital products created with performance and UX in mind."
  }
];
---

<section class="px-6 py-20">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.4fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-emerald-300">Impact Metrics</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-white md:text-4xl">
          Practical engineering measured by outcomes.
        </h2>
        <p class="mt-4 text-base leading-7 text-slate-400">
          I focus on shipping reliable software that helps teams move faster, improves product quality, and creates cleaner user experiences.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {metrics.map((metric) => (
          <article class="rounded-lg border border-slate-800 bg-slate-900/60 p-6">
            <p class="text-4xl font-bold tracking-tight text-cyan-300">{metric.value}</p>
            <h3 class="mt-3 text-base font-semibold text-white">{metric.label}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-400">{metric.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
