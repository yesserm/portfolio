---
import "../../styles/global.css"; // importa Tailwind
const { title = "Yesser Portfolio" } = Astro.props;
---
<html lang="es" class="bg-slate-950 text-slate-100">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen flex flex-col">
    <slot name="header" />
    <main class="flex-1">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
